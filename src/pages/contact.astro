---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — River Roots Studio" description="Get in touch with River Roots Studio. Ask questions or inquire about private workshops in Jacksonville, Illinois.">
  <!-- PAGE HEADER -->
  <section class="relative w-full overflow-hidden" style="height: clamp(300px, 35vw, 400px);">
    <img
      src="/images/hero-contact.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.35);"></div>
    <div class="relative h-full flex items-center justify-center px-4">
      <h1 class="text-[4rem] sm:text-[5rem] font-semibold leading-tight text-center" style="font-family: var(--font-accent); color: #ffffff; text-shadow: 0 1px 4px rgba(0,0,0,0.4);">
        Get in Touch
      </h1>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="py-10 sm:py-12 lg:py-14">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-brown/80 text-lg leading-relaxed text-center mb-8">
        Have a question? Want to inquire about a private workshop? I&rsquo;d love to hear from you.
      </p>

      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
        <div>
          <label for="name" class="block text-sm font-medium text-brown mb-1">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 border border-moss/30 rounded-md bg-white text-brown placeholder:text-brown/40 focus:outline-none focus:ring-2 focus:ring-moss focus:border-moss"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-brown mb-1">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 border border-moss/30 rounded-md bg-white text-brown placeholder:text-brown/40 focus:outline-none focus:ring-2 focus:ring-moss focus:border-moss"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-brown mb-1">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-3 border border-moss/30 rounded-md bg-white text-brown placeholder:text-brown/40 focus:outline-none focus:ring-2 focus:ring-moss focus:border-moss resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-6 py-3 bg-terracotta hover:bg-terracotta-dark text-cream rounded-md font-medium text-lg transition-colors focus:outline-none focus:ring-2 focus:ring-terracotta focus:ring-offset-2 focus:ring-offset-cream"
        >
          Send Message
        </button>
      </form>

      <p class="text-brown/60 text-sm text-center mt-8 italic">
        Based in Jacksonville, Illinois
      </p>
    </div>
  </section>
</Layout>
