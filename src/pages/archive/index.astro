---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Archive — River Roots Studio" description="Reflections, creative prompts, and stories from River Roots Studio.">
  <!-- PAGE HEADER -->
  <section class="relative w-full overflow-hidden" style="height: clamp(300px, 35vw, 400px);">
    <img
      src="/images/forest-sunbeams.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.35);"></div>
    <div class="relative h-full flex items-center justify-center px-4">
      <h1 class="text-[4rem] sm:text-[5rem] font-semibold leading-tight text-center" style="font-family: var(--font-accent); color: #ffffff; text-shadow: 0 1px 4px rgba(0,0,0,0.4);">
        Archive
      </h1>
    </div>
  </section>

  <!-- POST GRID -->
  <section class="py-10 sm:py-12 lg:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="text-center py-10">
          <p class="text-brown/60 text-lg italic font-heading">New reflections coming soon.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {posts.map((post) => (
            <a
              href={`/archive/${post.id}`}
              class="group bg-white border border-moss/10 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow"
            >
              <div class="p-6">
                <h2 class="font-heading text-xl font-semibold text-moss mb-2 group-hover:text-terracotta transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-brown/70 text-sm leading-relaxed">
                  {post.data.excerpt}
                </p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
