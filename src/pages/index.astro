---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import logoImport from '../assets/logo.webp';
const logoSrc = typeof logoImport === 'string' ? logoImport : logoImport.src;

const allWorkshops = await getCollection('workshops');
const featuredWorkshop = allWorkshops.find((w) => w.data.featured);
let FeaturedContent: any = null;
if (featuredWorkshop) {
  const rendered = await render(featuredWorkshop);
  FeaturedContent = rendered.Content;
}
---

<Layout>
  <!-- HERO -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero-river.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(20, 30, 15, 0.3) 0%, rgba(20, 30, 15, 0.5) 40%, rgba(20, 30, 15, 0.5) 60%, rgba(20, 30, 15, 0.2) 100%);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-16 sm:py-20">
      <h1 class="text-[3.5rem] sm:text-[4.5rem] lg:text-[5.5rem] font-semibold leading-tight mb-6" style="font-family: var(--font-accent); color: #FAF7F2; text-shadow: 0 1px 3px rgba(0,0,0,0.4);">
        River Roots Studio
      </h1>
      <p class="hero-body text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed text-center" style="color: #EDE8E0; text-shadow: 0 1px 3px rgba(0,0,0,0.4);">
        Rivers unfold at their own pace giving nourishment<br />like a creative practice.
      </p>
    </div>
  </section>

  <!-- INTRO DESCRIPTION -->
  <section class="pt-10 pb-5 sm:pt-12 sm:pb-6 lg:pt-14 lg:pb-7 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-left">
      <p class="text-brown/80 text-lg sm:text-xl leading-relaxed mb-4">
        River Roots offers workshops weaving expressive arts and ritual as a way for self-discovery.
      </p>
      <p class="text-brown/80 text-lg sm:text-xl leading-relaxed mb-4">
        I use natural elements, poetry, music, and writing in highly tactile workshops. These help to illuminate your own intuition and unearth the whispers of your deeper story.
      </p>
      <p class="text-brown/80 text-lg sm:text-xl leading-relaxed mb-6">
        By gathering in cozy spaces with kindred spirits, I hope to encourage you and enrich your daily life.
      </p>
    </div>
  </section>

  <!-- WHAT YOU'LL FIND HERE -->
  <section class="pt-5 pb-10 sm:pt-6 sm:pb-12 lg:pt-7 lg:pb-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-center text-moss mb-2">
        What You&rsquo;ll Find Here
      </h2>
      <p class="font-heading text-lg italic text-brown/60 text-center mb-8">A place&hellip;</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Item 1 -->
        <div class="text-center px-4 py-3">
          <div class="w-14 h-14 mx-auto mb-3 rounded-full flex items-center justify-center overflow-hidden" style="background-color: rgba(196, 149, 106, 0.25);" aria-hidden="true">
            <img src={logoSrc} alt="" class="w-10 h-10 object-contain mix-blend-multiply" />
          </div>
          <h3 class="font-heading text-lg font-semibold mb-1" style="color: #8B5E3C;">Of safety</h3>
          <p class="text-brown/70 text-sm leading-relaxed">to discover your inner knowing while having fun.</p>
        </div>

        <!-- Item 2 -->
        <div class="text-center px-4 py-3">
          <div class="w-14 h-14 mx-auto mb-3 rounded-full flex items-center justify-center overflow-hidden" style="background-color: rgba(196, 149, 106, 0.25);" aria-hidden="true">
            <img src={logoSrc} alt="" class="w-10 h-10 object-contain mix-blend-multiply" />
          </div>
          <h3 class="font-heading text-lg font-semibold mb-1" style="color: #8B5E3C;">Where your emotions can speak</h3>
          <p class="text-brown/70 text-sm leading-relaxed">enticed by art &amp; ritual to find expression.</p>
        </div>

        <!-- Item 3 -->
        <div class="text-center px-4 py-3">
          <div class="w-14 h-14 mx-auto mb-3 rounded-full flex items-center justify-center overflow-hidden" style="background-color: rgba(196, 149, 106, 0.25);" aria-hidden="true">
            <img src={logoSrc} alt="" class="w-10 h-10 object-contain mix-blend-multiply" />
          </div>
          <h3 class="font-heading text-lg font-semibold mb-1" style="color: #8B5E3C;">To contemplate truths</h3>
          <p class="text-brown/70 text-sm leading-relaxed">that will make sense, or surprise the hell out of you.</p>
        </div>

        <!-- Item 4 -->
        <div class="text-center px-4 py-3">
          <div class="w-14 h-14 mx-auto mb-3 rounded-full flex items-center justify-center overflow-hidden" style="background-color: rgba(196, 149, 106, 0.25);" aria-hidden="true">
            <img src={logoSrc} alt="" class="w-10 h-10 object-contain mix-blend-multiply" />
          </div>
          <h3 class="font-heading text-lg font-semibold mb-1" style="color: #8B5E3C;">Among kindred hearts</h3>
          <p class="text-brown/70 text-sm leading-relaxed">to engage with others and make some new friends.</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <a
          href="/workshops"
          class="inline-block bg-moss hover:bg-moss/90 text-cream px-8 py-3 rounded-md font-medium text-lg transition-colors focus:outline-none focus:ring-2 focus:ring-moss focus:ring-offset-2"
        >
          See Workshops
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURED WORKSHOP -->
  {featuredWorkshop && (
    <section class="py-10 sm:py-12 lg:py-14 bg-moss/5">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
          <div class="aspect-[4/3] rounded-lg overflow-hidden">
            {featuredWorkshop.data.heroImage ? (
              <Image
                src={featuredWorkshop.data.heroImage}
                alt={featuredWorkshop.data.heroImageAlt || featuredWorkshop.data.title}
                class="w-full h-full object-cover"
                widths={[400, 800]}
                sizes="(max-width: 1024px) 100vw, 50vw"
              />
            ) : (
              <div
                class="w-full h-full flex items-center justify-center"
                style="background: linear-gradient(135deg, #6B7C5C 0%, #556347 40%, #4A3728 100%);"
              />
            )}
          </div>

          <!-- Content -->
          <div>
            <p class="font-heading text-lg italic text-brown/70 mb-4 leading-relaxed">
              Your creativity runs in you like the marrow of your bones and the blood in your veins.
            </p>
            <p class="text-terracotta font-medium text-sm uppercase tracking-wider mb-2">Featured Workshop</p>
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-moss mb-2">
              {featuredWorkshop.data.title}
            </h2>
            <div class="text-brown/80 leading-relaxed mb-6 [&>p]:mb-3">
              <FeaturedContent />
            </div>
            <a
              href={`/contact?workshop=${encodeURIComponent(featuredWorkshop.data.title)}`}
              class="inline-block bg-terracotta hover:bg-terracotta-dark text-cream px-6 py-3 rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-terracotta focus:ring-offset-2 focus:ring-offset-cream"
            >
              {featuredWorkshop.data.status === 'upcoming' ? 'Express Interest' : 'Learn More & Register'}
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ABOUT TEASER -->
  <section class="py-10 sm:py-12 lg:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-10">
        <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full flex-shrink-0 overflow-hidden">
          <img
            src="/images/donna-1.jpg"
            alt="Donna, your guide at River Roots Studio"
            class="w-full h-full object-cover object-center"
          />
        </div>

        <!-- Text -->
        <div>
          <h2 class="font-heading text-3xl font-bold text-moss mb-3">Hi, I&rsquo;m Your Guide</h2>
          <p class="text-brown/80 leading-relaxed mb-3">
            I curate expressive art workshops as a wise spiritual director or life coach that doesn&rsquo;t advise you, but leads you to ask the questions that only your heart needs the answer for.
          </p>
          <a
            href="/about"
            class="text-terracotta hover:text-terracotta-dark font-medium transition-colors"
          >
            Meet Your Guide &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
