---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allWorkshops = await getCollection('workshops');
const workshops = allWorkshops
  .filter((w) => w.data.status !== 'archived')
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Workshops — River Roots Studio" description="Creative workshops in Expressive Arts, Spiritual Direction, and Ritual. Based in Jacksonville, Illinois.">
  <!-- PAGE HEADER -->
  <section class="relative w-full overflow-hidden" style="height: clamp(300px, 35vw, 400px);">
    <img
      src="/images/workshops-hero.webp"
      alt="A misty alpine forest with a glassy river reflecting tall pine trees and distant mountains"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.35);"></div>
    <div class="relative h-full flex items-center justify-center px-4">
      <h1 class="text-[4rem] sm:text-[5rem] font-semibold leading-tight text-center" style="font-family: var(--font-accent); color: #ffffff; text-shadow: 0 1px 4px rgba(0,0,0,0.4);">
        Workshops
      </h1>
    </div>
  </section>

  <!-- WORKSHOP LISTING -->
  <section class="py-10 sm:py-12 lg:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-stretch">
        {workshops.map((w) => (
          <a
            href={`/workshops/${w.id}`}
            class="group bg-white border border-moss/10 rounded-lg overflow-hidden shadow-sm flex flex-col transition-shadow hover:shadow-md"
          >
            <div class="relative overflow-hidden" style="height: 220px;">
              {w.data.heroImage ? (
                <Image
                  src={w.data.heroImage}
                  alt={w.data.heroImageAlt || w.data.title}
                  class="w-full h-full object-cover object-center transition-transform group-hover:scale-105"
                  style="height: 220px; width: 100%; object-fit: cover;"
                  widths={[400, 600]}
                  sizes="(max-width: 640px) 100vw, 50vw"
                />
              ) : (
                <div
                  class="w-full h-full flex items-center justify-center"
                  style="background: linear-gradient(135deg, #6B7C5C 0%, #556347 40%, #4A3728 100%);"
                >
                  <span class="text-cream/60 font-heading text-lg font-semibold tracking-wide">{w.data.title}</span>
                </div>
              )}
              {w.data.status === 'upcoming' && (
                <span class="absolute top-3 right-3 text-xs font-medium uppercase tracking-wider text-cream px-2 py-1 rounded" style="background-color: rgba(107, 124, 92, 0.85);">
                  Coming Soon
                </span>
              )}
            </div>
            <div class="p-4 flex-grow flex flex-col">
              <h3 class="font-heading text-lg font-semibold text-moss mb-1 group-hover:text-moss-dark transition-colors">{w.data.title}</h3>
              <p class="text-brown/60 text-sm leading-relaxed mb-3">{w.data.shortDescription}</p>
              <span class="text-moss font-medium text-sm mt-auto">Learn More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PRIVATE / GROUP INQUIRY -->
  <section class="py-10 sm:py-12 lg:py-14 bg-moss/5">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-moss mb-4">
        Private &amp; Group Workshops
      </h2>
      <p class="text-brown/80 text-lg leading-relaxed mb-6">
        Interested in a private or group workshop? You may invite four to seven others.
        Please reach out with at least a week&rsquo;s notice.
      </p>
      <a
        href="/contact"
        class="inline-block bg-terracotta hover:bg-terracotta-dark text-cream px-8 py-3 rounded-md font-medium text-lg transition-colors focus:outline-none focus:ring-2 focus:ring-terracotta focus:ring-offset-2 focus:ring-offset-cream"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
